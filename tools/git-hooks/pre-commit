#!/usr/bin/env bash
# Pre-commit guard: block a commit whose derived files are out of sync with the PRD.
# Install once per clone:   ln -sf ../../tools/git-hooks/pre-commit .git/hooks/pre-commit
# (or copy it there and `chmod +x .git/hooks/pre-commit`).
#
# It runs the splitter in NON-MUTATING verify mode. If someone edited the PRD without
# re-running the splitter (so build-view/ · specs/contracts/ · .agents/workflows/build-*.md
# are stale), the commit is refused with instructions.
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
if ! python3 "$ROOT/tools/build_view_split.py" --verify; then
  echo ""
  echo "commit refused: derived files are out of sync with the PRD."
  echo "run:  python3 tools/build_view_split.py    # regenerate"
  echo "then: git add -A && commit again (PRD edit + regenerated derived files together)."
  exit 1
fi
