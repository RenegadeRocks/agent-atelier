# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/
venv/

# Secrets — never commit real secrets; only secrets_ref lives in the repo (secrets.md)
.env
*.key
*.pem
secrets.local.*

# Build/test artifacts (product code the build will create).
# NOTE: build/ and dist/ are ignored as ARTIFACT dirs. When P0 proposes the product
# source tree, do NOT name a SOURCE directory build/ or dist/ (it would be silently
# untracked and lost on `git pull`). Prefer a package dir like app/ and scope any
# artifact ignores under it (e.g. app/dist/). build-view/ is intentionally NOT ignored.
node_modules/
dist/
build/
.pytest_cache/
*.log

# Antigravity / editor local state (per-machine; does not travel)
.idea/
.vscode/
*.local
.gstack/
circuit_breaker_state.json
ui/studio-floor/data/state.json
ui/studio-floor/data/actions.jsonl
atelier-sor.json
keys/
